{
  "name": "kmd",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @kmd/editor dev",
    "build": "pnpm --filter @kmd/editor build",
    "preview": "pnpm --filter @kmd/editor preview",
    "test": "pnpm --filter @kmd/editor test",
    "test:parser": "pnpm --filter @kmd/editor test:parser",
    "test:shaders": "pnpm --filter @kmd/editor test:shaders",
    "test:e2e": "pnpm reader:build && playwright test",
    "test:e2e:run": "playwright test",
    "language:check": "node scripts/check-language-assets.mjs",
    "editor:dev": "pnpm --filter @kmd/editor dev",
    "editor:build": "pnpm --filter @kmd/editor build",
    "editor:preview": "pnpm --filter @kmd/editor preview",
    "reader:typecheck": "pnpm --filter @kmd/reader-runtime-web typecheck",
    "reader:build": "pnpm --filter @kmd/reader-runtime-web build",
    "reader:preview": "pnpm --filter @kmd/reader-runtime-web preview",
    "community-api:dev": "pnpm --filter @kmd/community-api dev",
    "community-api:build": "pnpm --filter @kmd/community-api build",
    "community-api:test": "pnpm --filter @kmd/community-api test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
